<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="AppButton">
        <attr name="buttonText" format="string" />
        <attr name="buttonVariant">
            <enum name="primary" value="0" />
            <enum name="secondary" value="1" />
            <enum name="outline" value="2" />
            <enum name="danger" value="3" />
            <enum name="ghost" value="4" />
        </attr>
        <attr name="buttonSize">
            <enum name="small" value="0" />
            <enum name="medium" value="1" />
            <enum name="large" value="2" />
        </attr>
        <attr name="buttonRounded">
            <enum name="small" value="0" />
            <enum name="medium" value="1" />
            <enum name="full" value="2" />
        </attr>
        <attr name="leftIcon" format="reference" />
        <attr name="rightIcon" format="reference" />
        <attr name="isLoading" format="boolean" />
    </declare-styleable>
</resources>